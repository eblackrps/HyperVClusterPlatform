[ClassVersion("2.0.0"), FriendlyName("HVClusterResource")]
class HVClusterResource : OMI_BaseResource
{
  [Key,      Description("Cluster name (must match Active Directory CNO)")]      string ClusterName;
  [Required, Description("Static IP address for the cluster name object")]       string StaticAddress;
  [Required, Description("Array of cluster node hostnames")]                     string Nodes[];
  [Write, ValueMap{"None","Disk","Cloud","Share"}, Values{"None","Disk","Cloud","Share"},
           Description("Quorum witness type. Default: None")]                    string WitnessType;
  [Write, ValueMap{"Present","Absent"}, Values{"Present","Absent"},
           Description("Whether the cluster should exist. Default: Present")]    string Ensure;
  [Write,    Description("Exact cluster disk witness resource name (WitnessType=Disk)")] string WitnessDiskName;
  [Write,    Description("UNC path to file share witness (WitnessType=Share)")]  string FileShareWitness;
  [Write,    Description("Azure storage account name for cloud witness")]         string CloudWitnessStorageAccount;
  [Write,    Description("Azure storage access key for cloud witness")]           string CloudWitnessStorageKey;
};
